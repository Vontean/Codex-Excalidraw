# Optional runtime overrides.
# The setup script also writes ~/.codex-excalidraw/config.json for local agents.

# Directory used as the local workbench root.
# EXCALIDRAW_CODEX_HOME=~/Codex-Excalidraw

# Directory where .excalidraw, .png, .svg, and snapshots are written.
# EXCALIDRAW_CODEX_ARTIFACTS_DIR=~/Codex-Excalidraw/artifacts/excalidraw

# Directory containing config.json.
# EXCALIDRAW_CODEX_CONFIG_DIR=~/.codex-excalidraw

# Default Excalidraw font for generated diagrams.
# Supported: Nunito, Excalifont, Virgil, Helvetica, Cascadia, Lilita One, Comic Shanns, Liberation Sans.
# EXCALIDRAW_CODEX_FONT=Nunito

# Maximum snapshots kept per scene. Use 0 to disable automatic pruning.
# EXCALIDRAW_CODEX_SNAPSHOT_LIMIT=80

# Workbench URL used by MCP/export helpers when rendering screenshots or assets.
# EXCALIDRAW_CODEX_WORKBENCH_URL=http://127.0.0.1:3000/

# Browser executable used for PNG/SVG export and Mermaid conversion.
# If unset, Codex Excalidraw tries the Playwright cache first, then system Chrome/Chromium.
# EXCALIDRAW_CODEX_BROWSER_EXECUTABLE=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Optional Playwright channel such as chrome or msedge.
# EXCALIDRAW_CODEX_BROWSER_CHANNEL=chrome

# Upload endpoint used only by explicit `share` / `export_to_excalidraw_url` commands.
# EXCALIDRAW_CODEX_SHARE_ENDPOINT=https://json.excalidraw.com/api/v2/post/
