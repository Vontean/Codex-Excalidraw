{
  "name": "codex-excalidraw",
  "version": "0.1.0",
  "description": "Local Excalidraw workbench, CLI, and agent skill for Codex and Claude Code.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vontean/Codex-Excalidraw.git"
  },
  "keywords": [
    "codex",
    "claude-code",
    "excalidraw",
    "diagram",
    "whiteboard",
    "skill"
  ],
  "type": "module",
  "bin": {
    "excalidraw-codex": "./bin/excalidraw-codex.mjs"
  },
  "scripts": {
    "setup": "node ./scripts/install.mjs",
    "dev": "node ./bin/excalidraw-codex.mjs serve",
    "build": "tsc --noEmit && vite build",
    "preview": "NODE_ENV=production node ./bin/excalidraw-codex.mjs serve",
    "cli": "node ./bin/excalidraw-codex.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "0.18.1",
    "@excalidraw/mermaid-to-excalidraw": "2.2.2",
    "express": "^4.18.3",
    "lucide-react": "^0.468.0",
    "playwright": "^1.56.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
